---
// Player component — landing page
// Title sits between fluid back/front layers
---

<!-- SVG filter for text distortion — static turbulence, no animation -->
<svg class="svg-filters" aria-hidden="true">
  <defs>
    <filter id="fluid-text" x="-10%" y="-15%" width="120%" height="130%" color-interpolation-filters="sRGB">
      <feTurbulence type="fractalNoise" baseFrequency="0.009 0.007" numOctaves="2" seed="4" result="noise"/>
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="3" xChannelSelector="R" yChannelSelector="G"/>
    </filter>
  </defs>
</svg>

<div class="player">
  <div class="player-title-wrap">
    <h1 id="player-title" class="player-title player-title--active" data-text="MORPHICS">MORPHICS</h1>
    <h1 id="player-title-alt" class="player-title player-title--incoming" aria-hidden="true"></h1>
  </div>

  <div class="player-spacer"></div>

  <div class="player-controls is-intro">
    <button class="ctrl-btn" aria-label="Repeat">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M7 7h10v3l4-4-4-4v3H5v6h2V7zm10 10H7v-3l-4 4 4 4v-3h12v-6h-2v4z"/>
      </svg>
    </button>

    <button id="player-prev" class="ctrl-btn" aria-label="Previous track">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/>
      </svg>
    </button>

    <button id="player-play" class="ctrl-btn ctrl-play" aria-label="Play">
      <span class="play-ripple"></span>
      <span class="play-ripple play-ripple--b"></span>
      <span class="play-ripple play-ripple--c"></span>
      <span class="play-ripple play-ripple--d"></span>
      <span class="play-ripple play-ripple--e"></span>
      <span class="play-glow"></span>
      <span class="play-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
          <path d="M8 5v14l11-7z"/>
        </svg>
      </span>
      <span class="pause-icon" style="display:none;">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
        </svg>
      </span>
    </button>

    <button id="player-next" class="ctrl-btn" aria-label="Next track">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/>
      </svg>
    </button>

    <div class="volume-wrap">
      <button id="player-volume" class="ctrl-btn" aria-label="Volume">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
        </svg>
      </button>
      <div class="volume-slider" id="volume-slider">
        <input type="range" min="0" max="100" value="100" class="volume-range" id="volume-range" aria-label="Volume level">
      </div>
    </div>
  </div>
</div>

<style>
  .player {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 14vh var(--space-6) 8vh;
    position: relative;
    pointer-events: none;
  }

  .player-title-wrap {
    pointer-events: auto;
    position: relative;
    z-index: 4; /* behind blob-wrap (z-index 5) */
  }

  .player-controls {
    pointer-events: auto;
    position: relative;
    z-index: 6; /* above blob-wrap (z-index 5) */
  }

  .player-spacer {
    flex: 1;
  }

  /* --- Title --- */
  .player-title-wrap {
    min-height: 1.2em;
    cursor: default;
    transition: opacity 2.5s ease;
  }

  .player-title :global(.title-letter) {
    display: inline-block;
    transform-origin: center bottom;
    text-shadow:
      0 0 6px rgba(0, 0, 0, 0.4),
      0 0 20px rgba(0, 0, 0, 0.15);
    filter: drop-shadow(1px 2px 2px rgba(0, 0, 0, 0.5));
  }

  .svg-filters {
    position: absolute;
    width: 0;
    height: 0;
    overflow: hidden;
  }

  .player-title {
    font-family: 'Rubik', sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: rgba(245, 242, 236, 0.96);
    text-align: center;
    user-select: none;
    line-height: 1;
    padding: 0.2em 0.5em;
    white-space: nowrap;
    text-shadow:
      0 0 40px rgba(0, 0, 0, 0.15),
      0 0 120px rgba(0, 0, 0, 0.08);
    transform: scale(var(--title-scale, 1));
    filter: url(#fluid-text);

    -webkit-mask-image:
      linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
    mask-image:
      linear-gradient(to right, transparent 0%, black 15%, black 85%, transparent 100%);
  }

  .player-title--active {
    position: relative;
    opacity: 1.0;
    animation: title-breathe 22s ease-in-out infinite;
    transition: transform 0.15s ease, text-shadow 0.15s ease;
  }

  .player-title--incoming {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%) scale(var(--title-scale, 1));
    opacity: 0;
  }

  /* Morphing: kill breathe animation while transitioning */
  .player-title.is-morphing {
    animation: none !important;
  }

  @keyframes title-breathe {
    0%, 100% { opacity: 1.0; }
    30%      { opacity: 0.82; }
    50%      { opacity: 0.95; }
    70%      { opacity: 0.78; }
    90%      { opacity: 0.92; }
  }

  /* --- Transport controls --- */
  .player-controls {
    display: flex;
    align-items: center;
    gap: 20px;
    overflow: visible;
    padding: 8px;
    transition: transform 2s cubic-bezier(0.4, 0, 0.2, 1), opacity 2.5s ease;
  }

  .ctrl-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 46px;
    height: 46px;
    border-radius: 40% 45% 42% 48% / 44% 40% 46% 42%;
    background: rgba(255, 255, 255, 0.14);
    border: none;
    cursor: pointer;
    color: rgba(235, 230, 222, 0.9);
    transition: color 0.28s ease, background 0.28s ease, box-shadow 0.28s ease, border-radius 0.4s ease, transform 0.3s ease;
    box-shadow:
      inset 0 1px 1px rgba(255,255,255,0.14),
      0 4px 12px rgba(0,0,0,0.3);
    transform-origin: center;
    overflow: visible;
  }

  .ctrl-btn:hover {
    color: rgba(250, 248, 244, 1.0);
    background: rgba(255, 255, 255, 0.20);
    box-shadow:
      inset 0 1px 1px rgba(255,255,255,0.18),
      0 0 10px rgba(255,255,255,0.10),
      0 4px 12px rgba(0,0,0,0.3);
    transform: scale(1.12);
  }

  .ctrl-btn:active {
    transform: scale(0.92);
    transition: transform 0.08s ease;
    animation: none;
  }

  .ctrl-play {
    width: 58px;
    height: 58px;
    border-radius: 42% 46% 44% 48% / 46% 42% 48% 44%;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(235, 230, 222, 0.95);
  }

  .ctrl-play:hover {
    background: rgba(255, 255, 255, 0.22);
    color: rgba(250, 248, 244, 1.0);
    box-shadow:
      inset 0 1px 1px rgba(255,255,255,0.20),
      0 0 12px rgba(255,255,255,0.12),
      0 4px 14px rgba(0,0,0,0.3);
    transform: scale(1.14);
  }

  .ctrl-play .play-icon,
  .ctrl-play .pause-icon {
    transition: transform 0.3s ease;
  }

  .ctrl-play:hover .play-icon,
  .ctrl-play:hover .pause-icon {
    transform: scale(1.15);
  }

  /* Each button gets its own morph animation — unique shapes, different durations */
  .ctrl-btn:nth-child(1) { animation: morph-a 16s ease-in-out infinite; }
  .ctrl-btn:nth-child(2) { animation: morph-b 19s ease-in-out infinite; }
  .ctrl-btn:nth-child(3) { animation: morph-c 22s ease-in-out infinite; }
  .ctrl-btn:nth-child(4) { animation: morph-d 17s ease-in-out infinite; }
  .ctrl-btn:nth-child(5) { animation: morph-e 20s ease-in-out infinite; }

  .ctrl-btn:active { animation: none; }

  /* Each button gets its own morph — values stay 40%-60% to never clip the box edge */
  @keyframes morph-a {
    0%   { border-radius: 42% 58% 46% 54% / 54% 44% 56% 46%; }
    5%   { border-radius: 52% 48% 56% 44% / 44% 58% 42% 58%; }
    11%  { border-radius: 58% 42% 42% 58% / 56% 46% 54% 44%; }
    17%  { border-radius: 44% 56% 54% 46% / 46% 54% 58% 42%; }
    23%  { border-radius: 54% 46% 58% 42% / 42% 56% 44% 56%; }
    30%  { border-radius: 46% 54% 44% 56% / 58% 42% 56% 46%; }
    37%  { border-radius: 56% 44% 42% 58% / 48% 52% 46% 54%; }
    44%  { border-radius: 42% 58% 56% 44% / 54% 44% 52% 48%; }
    52%  { border-radius: 54% 46% 44% 56% / 42% 58% 48% 52%; }
    60%  { border-radius: 48% 52% 58% 42% / 56% 42% 44% 58%; }
    68%  { border-radius: 56% 44% 48% 52% / 44% 54% 58% 42%; }
    76%  { border-radius: 44% 56% 52% 48% / 58% 46% 42% 56%; }
    84%  { border-radius: 52% 48% 44% 56% / 46% 56% 54% 44%; }
    92%  { border-radius: 46% 54% 56% 44% / 52% 48% 46% 54%; }
    100% { border-radius: 42% 58% 46% 54% / 54% 44% 56% 46%; }
  }

  @keyframes morph-b {
    0%   { border-radius: 48% 52% 54% 46% / 46% 56% 44% 56%; }
    6%   { border-radius: 44% 56% 48% 52% / 52% 44% 58% 44%; }
    13%  { border-radius: 56% 44% 58% 42% / 42% 58% 46% 54%; }
    19%  { border-radius: 46% 54% 42% 58% / 58% 46% 52% 44%; }
    26%  { border-radius: 58% 42% 52% 48% / 44% 54% 42% 58%; }
    33%  { border-radius: 42% 58% 56% 44% / 54% 42% 58% 46%; }
    40%  { border-radius: 54% 46% 44% 56% / 48% 56% 44% 52%; }
    48%  { border-radius: 44% 56% 58% 42% / 56% 42% 52% 48%; }
    56%  { border-radius: 56% 44% 46% 54% / 42% 52% 48% 56%; }
    64%  { border-radius: 48% 52% 52% 48% / 54% 48% 42% 54%; }
    72%  { border-radius: 54% 46% 42% 58% / 46% 56% 54% 42%; }
    80%  { border-radius: 42% 58% 48% 52% / 58% 44% 46% 58%; }
    88%  { border-radius: 52% 48% 56% 44% / 44% 52% 56% 46%; }
    94%  { border-radius: 46% 54% 44% 56% / 52% 48% 44% 52%; }
    100% { border-radius: 48% 52% 54% 46% / 46% 56% 44% 56%; }
  }

  @keyframes morph-c {
    0%   { border-radius: 52% 48% 44% 56% / 56% 48% 52% 42%; }
    4%   { border-radius: 44% 56% 52% 48% / 48% 54% 44% 56%; }
    9%   { border-radius: 58% 42% 46% 54% / 42% 58% 56% 42%; }
    15%  { border-radius: 42% 58% 58% 42% / 56% 42% 42% 54%; }
    21%  { border-radius: 54% 46% 44% 56% / 46% 52% 54% 48%; }
    28%  { border-radius: 46% 54% 56% 44% / 52% 44% 46% 58%; }
    35%  { border-radius: 56% 44% 48% 52% / 42% 58% 52% 44%; }
    42%  { border-radius: 44% 56% 52% 48% / 58% 44% 42% 52%; }
    50%  { border-radius: 52% 48% 42% 58% / 46% 52% 58% 46%; }
    58%  { border-radius: 48% 52% 56% 44% / 54% 42% 44% 56%; }
    65%  { border-radius: 56% 44% 44% 56% / 42% 56% 52% 46%; }
    72%  { border-radius: 42% 58% 54% 46% / 52% 46% 44% 58%; }
    80%  { border-radius: 52% 48% 46% 54% / 44% 56% 48% 52%; }
    88%  { border-radius: 46% 54% 52% 48% / 58% 42% 56% 44%; }
    94%  { border-radius: 50% 50% 48% 52% / 48% 52% 50% 50%; }
    100% { border-radius: 52% 48% 44% 56% / 56% 48% 52% 42%; }
  }

  @keyframes morph-d {
    0%   { border-radius: 46% 54% 56% 44% / 44% 52% 46% 56%; }
    5%   { border-radius: 56% 44% 42% 58% / 52% 46% 56% 42%; }
    12%  { border-radius: 42% 58% 52% 48% / 58% 42% 44% 54%; }
    19%  { border-radius: 52% 48% 46% 54% / 44% 56% 52% 46%; }
    27%  { border-radius: 46% 54% 58% 42% / 54% 44% 46% 58%; }
    35%  { border-radius: 58% 42% 44% 56% / 42% 52% 56% 44%; }
    43%  { border-radius: 44% 56% 52% 48% / 56% 46% 42% 52%; }
    51%  { border-radius: 52% 48% 46% 54% / 46% 58% 52% 48%; }
    60%  { border-radius: 48% 52% 56% 44% / 52% 42% 46% 56%; }
    68%  { border-radius: 56% 44% 48% 52% / 42% 54% 58% 42%; }
    76%  { border-radius: 42% 58% 54% 46% / 54% 46% 42% 52%; }
    84%  { border-radius: 54% 46% 42% 58% / 46% 56% 52% 46%; }
    92%  { border-radius: 48% 52% 52% 48% / 56% 44% 48% 54%; }
    100% { border-radius: 46% 54% 56% 44% / 44% 52% 46% 56%; }
  }

  @keyframes morph-e {
    0%   { border-radius: 56% 44% 48% 52% / 52% 48% 56% 44%; }
    5%   { border-radius: 44% 56% 54% 46% / 46% 56% 42% 58%; }
    11%  { border-radius: 52% 48% 42% 58% / 58% 42% 54% 46%; }
    18%  { border-radius: 48% 52% 56% 44% / 42% 52% 46% 54%; }
    25%  { border-radius: 56% 44% 46% 54% / 54% 46% 58% 42%; }
    32%  { border-radius: 42% 58% 52% 48% / 46% 58% 44% 52%; }
    40%  { border-radius: 54% 46% 44% 56% / 56% 42% 52% 48%; }
    48%  { border-radius: 46% 54% 58% 42% / 42% 54% 48% 56%; }
    56%  { border-radius: 58% 42% 48% 52% / 52% 46% 56% 44%; }
    64%  { border-radius: 42% 58% 52% 48% / 44% 58% 42% 54%; }
    72%  { border-radius: 54% 46% 44% 56% / 58% 42% 52% 46%; }
    80%  { border-radius: 44% 56% 56% 44% / 48% 52% 44% 58%; }
    88%  { border-radius: 52% 48% 42% 58% / 54% 44% 56% 46%; }
    94%  { border-radius: 48% 52% 52% 48% / 48% 52% 48% 52%; }
    100% { border-radius: 56% 44% 48% 52% / 52% 48% 56% 44%; }
  }

  /* --- Volume slider --- */
  .volume-wrap {
    position: relative;
    pointer-events: auto;
  }

  .volume-slider {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 8px 16px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .volume-wrap:hover .volume-slider,
  .volume-slider:hover {
    opacity: 1;
    pointer-events: auto;
  }

  .volume-range {
    -webkit-appearance: none;
    appearance: none;
    width: 4px;
    height: 90px;
    background: rgba(255, 255, 255, 0.18);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
    writing-mode: vertical-lr;
    direction: rtl;
  }

  .volume-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(230, 224, 215, 0.9);
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .volume-range::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(230, 224, 215, 0.9);
    border: none;
    cursor: pointer;
  }

  .volume-range::-webkit-slider-thumb:hover {
    background: rgba(255, 255, 255, 0.95);
  }

  .volume-range::-moz-range-thumb:hover {
    background: rgba(255, 255, 255, 0.95);
  }

  /* --- Ripple rings (visible in intro only) --- */
  .play-ripple {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0);
    pointer-events: none;
    opacity: 0;
    z-index: -1;
  }

  .player-controls.is-intro .play-ripple {
    animation: ripple-out 3s ease-out infinite;
  }

  .player-controls.is-intro .play-ripple--b {
    animation: ripple-out-b 3s ease-out infinite;
  }

  .player-controls.is-intro .play-ripple--c {
    animation: ripple-out-c 3s ease-out infinite;
  }

  .player-controls.is-intro .play-ripple--d {
    animation: ripple-out-d 3s ease-out infinite;
  }

  .player-controls.is-intro .play-ripple--e {
    animation: ripple-out-e 3s ease-out infinite;
  }

  @keyframes ripple-out {
    0%   { transform: scale(1); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    44%  { transform: scale(1); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    45%  { transform: scale(1); opacity: 0.4; border-color: rgba(255, 255, 255, 0.25); }
    60%  { transform: scale(3); opacity: 0.15; border-color: rgba(255, 255, 255, 0.10); }
    85%  { transform: scale(6); opacity: 0.03; border-color: rgba(255, 255, 255, 0.02); }
    100% { transform: scale(7); opacity: 0; border-color: rgba(255, 255, 255, 0); }
  }

  @keyframes ripple-out-b {
    0%   { transform: scale(1); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    46%  { transform: scale(1); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    47%  { transform: scale(1); opacity: 0.3; border-color: rgba(255, 255, 255, 0.18); }
    65%  { transform: scale(4); opacity: 0.10; border-color: rgba(255, 255, 255, 0.06); }
    90%  { transform: scale(8); opacity: 0.02; border-color: rgba(255, 255, 255, 0.01); }
    100% { transform: scale(9); opacity: 0; border-color: rgba(255, 255, 255, 0); }
  }

  @keyframes ripple-out-c {
    0%   { transform: scale(1); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    48%  { transform: scale(1); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    49%  { transform: scale(1); opacity: 0.22; border-color: rgba(255, 255, 255, 0.12); }
    70%  { transform: scale(5); opacity: 0.06; border-color: rgba(255, 255, 255, 0.04); }
    95%  { transform: scale(10); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    100% { transform: scale(10); opacity: 0; border-color: rgba(255, 255, 255, 0); }
  }

  @keyframes ripple-out-d {
    0%   { transform: scale(1); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    50%  { transform: scale(1); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    51%  { transform: scale(1); opacity: 0.16; border-color: rgba(255, 255, 255, 0.08); }
    75%  { transform: scale(6); opacity: 0.04; border-color: rgba(255, 255, 255, 0.02); }
    98%  { transform: scale(12); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    100% { transform: scale(12); opacity: 0; border-color: rgba(255, 255, 255, 0); }
  }

  @keyframes ripple-out-e {
    0%   { transform: scale(1); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    52%  { transform: scale(1); opacity: 0; border-color: rgba(255, 255, 255, 0); }
    53%  { transform: scale(1); opacity: 0.10; border-color: rgba(255, 255, 255, 0.05); }
    80%  { transform: scale(7); opacity: 0.02; border-color: rgba(255, 255, 255, 0.01); }
    100% { transform: scale(14); opacity: 0; border-color: rgba(255, 255, 255, 0); }
  }

  /* --- Breathing glow halo (intro only) --- */
  .play-glow {
    position: absolute;
    inset: -16px;
    border-radius: 50%;
    pointer-events: none;
    opacity: 0;
    z-index: -1;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.06) 0%, transparent 50%);
  }

  .player-controls.is-intro .play-glow {
    animation: glow-pulse 3s ease-out infinite;
  }

  .player-controls.is-intro .ctrl-play.intro-rising .play-ripple,
  .player-controls.is-intro .ctrl-play.intro-hovering .play-ripple,
  .player-controls.is-intro .ctrl-play.intro-rising .play-ripple--d,
  .player-controls.is-intro .ctrl-play.intro-rising .play-ripple--e,
  .player-controls.is-intro .ctrl-play.intro-hovering .play-ripple--d,
  .player-controls.is-intro .ctrl-play.intro-hovering .play-ripple--e {
    animation: none;
    opacity: 0;
  }

  .player-controls.is-intro .ctrl-play.intro-hovering .play-glow {
    animation: intro-hover-glow 2s ease-in-out infinite;
  }

  @keyframes intro-hover-glow {
    0%   { opacity: 0.12; transform: scale(1.3); }
    50%  { opacity: 0.06; transform: scale(1.5); }
    100% { opacity: 0.12; transform: scale(1.3); }
  }

  @keyframes glow-pulse {
    0%   { opacity: 0; transform: scale(1); }
    25%  { opacity: 0.04; transform: scale(1.15); }
    35%  { opacity: 0.08; transform: scale(1.25); }
    45%  { opacity: 0.12; transform: scale(1.35); }
    55%  { opacity: 0.06; transform: scale(1.25); }
    68%  { opacity: 0.02; transform: scale(1.1); }
    80%  { opacity: 0; transform: scale(1); }
    100% { opacity: 0; transform: scale(1); }
  }

  /* --- Pulsing concentric ring (intro only) --- */
  .player-controls.is-intro .ctrl-play {
    background: rgba(255, 255, 255, 0.12);
    box-shadow: inset 0 1px 1px rgba(255,255,255,0.12);
    animation: intro-blob 3s ease-out infinite;
  }

  @keyframes intro-pulse-ring {
    0%   { box-shadow: inset 0 1px 1px rgba(255,255,255,0.06), 0 0 0 0px rgba(255, 255, 255, 0); }
    44%  { box-shadow: inset 0 1px 1px rgba(255,255,255,0.06), 0 0 0 0px rgba(255, 255, 255, 0); }
    45%  { box-shadow: inset 0 1px 1px rgba(255,255,255,0.06), 0 0 8px rgba(255, 255, 255, 0.06), 0 0 0 0px rgba(255, 255, 255, 0.08); }
